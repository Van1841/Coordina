# ============================================================
# COORDINA — Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# --------------------------------------------------------------
# MySQL
# --------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=coordina
MYSQL_PASSWORD=coordina_dev_password
MYSQL_DATABASE=coordina

# --------------------------------------------------------------
# LLM Providers
# Gemini is primary. Groq is the automatic fallback if Gemini
# errors, times out, or is rate-limited. See src/llm/llmRouter.js
# --------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# --------------------------------------------------------------
# Dashboard / API server
# --------------------------------------------------------------
PORT=4000
DASHBOARD_ORIGIN=http://localhost:5173

# --------------------------------------------------------------
# Slack Workspaces (Slack Connect)
# One Bolt app instance is created per organization workspace.
# Add / remove blocks below to match the orgs you actually
# provision in Slack. Each org needs its own app in
# https://api.slack.com/apps with Socket Mode enabled,
# an App-Level Token (xapp-...) with connections:write scope,
# and a Bot Token (xoxb-...) with the scopes listed in README.md.
# --------------------------------------------------------------

# --- NGO (Coordina home workspace, hosts the coordinator bot UX)
NGO_SLACK_BOT_TOKEN=xoxb-ngo-REPLACE_ME
NGO_SLACK_APP_TOKEN=xapp-ngo-REPLACE_ME
NGO_SLACK_SIGNING_SECRET=REPLACE_ME
NGO_ORG_ID=ngo_relief_trust

# --- Hospital
HOSPITAL_SLACK_BOT_TOKEN=xoxb-hospital-REPLACE_ME
HOSPITAL_SLACK_APP_TOKEN=xapp-hospital-REPLACE_ME
HOSPITAL_SLACK_SIGNING_SECRET=REPLACE_ME
HOSPITAL_ORG_ID=city_general_hospital

# --- Volunteer Organization
VOLUNTEER_SLACK_BOT_TOKEN=xoxb-volunteer-REPLACE_ME
VOLUNTEER_SLACK_APP_TOKEN=xapp-volunteer-REPLACE_ME
VOLUNTEER_SLACK_SIGNING_SECRET=REPLACE_ME
VOLUNTEER_ORG_ID=volunteer_corps

# --- Food Bank
FOODBANK_SLACK_BOT_TOKEN=xoxb-foodbank-REPLACE_ME
FOODBANK_SLACK_APP_TOKEN=xapp-foodbank-REPLACE_ME
FOODBANK_SLACK_SIGNING_SECRET=REPLACE_ME
FOODBANK_ORG_ID=regional_food_bank

# --------------------------------------------------------------
# Real-Time Search (RTS)
# Coordina uses RTS to watch live Slack + external signal
# instead of polling. See src/rts/realtimeSearch.js for why.
# If you have a real RTS/websearch provider key, set it here —
# otherwise the local event-bus + web fallback is used.
# --------------------------------------------------------------
RTS_PROVIDER_API_KEY=

# --------------------------------------------------------------
# Misc
# --------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=development
